{
  "name": "voice-persona-local",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist:win": "electron-builder --win nsis"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.persona.voicelab",
    "productName": "페르소나 대화하기",
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "package.json",
      "README.md"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "페르소나-대화하기-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "페르소나 대화하기"
    }
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.60.0"
  }
}
