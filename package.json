{
  "name": "voice-persona-local",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist:win": "electron-builder --win nsis"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.persona.voicelab",
    "productName": "Persona Voice Lab",
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "package.json",
      "README.md"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Persona-Voice-Lab-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Persona Voice Lab"
    }
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3"
  }
}
